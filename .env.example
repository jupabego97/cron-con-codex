# Application
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=replace-with-a-long-random-local-development-value

# Infrastructure (used from Phase 1 onward)
DATABASE_URL=postgresql://app:local-dev-only@localhost:5432/retail_platform
REDIS_URL=redis://localhost:6379/0

# Alegra: set only in your local secret store or deployment platform.
# This value is the Basic token (base64(email:token)); never commit a real value.
ALEGRA_API_BASIC_TOKEN=

# Include this high-entropy value as the `token` query parameter in the webhook URL.
# Example: https://your-domain/webhooks/alegra/acme?token=your-secret
ALEGRA_WEBHOOK_SECRET=
